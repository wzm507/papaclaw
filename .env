# Application
# Server Configuration (NestJS)
SUDA_DATABASE_URL=

# 本地开发：Lark Apaas 平台 HTTP 客户端所需（否则 Nest 无法启动，Vite 代理 HTML 会 502）
FORCE_AUTHN_INNERAPI_DOMAIN=http://localhost:3000
FORCE_AUTHN_ACCESS_KEY=local-dev
FORCE_AUTHN_ACCESS_SECRET=local-dev-secret

# 无数据库时需在启动命令中设置 FORCE_FRAMEWORK_DISABLE_DATAPASS=true（见 npm run dev:server）

# Client Configuration

# Logger
LOG_REQUEST_BODY=true
LOG_RESPONSE_BODY=true
